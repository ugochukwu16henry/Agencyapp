generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PARTNER
  AGENT
  INVESTOR
  USER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PropertyCategory {
  LAND
  HOUSE
  APARTMENT
}

enum PropertyType {
  RENT
  SALE
  DEVELOPMENT
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  UNDER_CONSTRUCTION
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  name          String
  role          Role         @default(USER)
  equityPercent Float        @default(0)
  properties    Property[]
  agentProfile  AgentProfile?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  audits        AuditLog[]   @relation("ActorAudits")
}

model Property {
  id                 String              @id @default(uuid())
  title              String
  slug               String              @unique
  description        String
  price              Decimal
  currency           String              @default("SLE")
  category           PropertyCategory
  type               PropertyType
  status             PropertyStatus      @default(AVAILABLE)
  location           String
  locationLat        Float?
  locationLng        Float?
  verificationStatus VerificationStatus  @default(PENDING)
  trustTier          String              @default("MINISTRY_VERIFIED")
  whatsappNumber     String?
  coverImageUrl      String?
  isVerified         Boolean             @default(false)
  sitePlanUrl        String?
  constructionStep   Int                 @default(0)
  projectPhase       String?
  assetLedgerRef     String?
  ownerId            String
  owner              User                @relation(fields: [ownerId], references: [id])
  documents          PropertyDocument[]
  media              PropertyMedia[]
  leads              Lead[]
  verifiedBy         String?
  verifiedAt         DateTime?
  verificationEvents VerificationEvent[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
}

model PropertyDocument {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  type       String
  url        String
  isPrivate  Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model PropertyMedia {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  url        String
  position   Int      @default(0)
  createdAt  DateTime @default(now())
}

model VerificationEvent {
  id         String             @id @default(uuid())
  propertyId String
  property   Property           @relation(fields: [propertyId], references: [id])
  actorId    String
  previous   VerificationStatus
  next       VerificationStatus
  note       String?
  createdAt  DateTime           @default(now())
}

model Lead {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  channel    String
  source     String?
  createdAt  DateTime @default(now())
}

model AgentProfile {
  id           String         @id @default(uuid())
  userId       String         @unique
  user         User           @relation(fields: [userId], references: [id])
  companyName  String
  licenseNumber String?
  subscriptions Subscription[]
  createdAt    DateTime       @default(now())
}

model Subscription {
  id          String               @id @default(uuid())
  agentId     String
  agent       AgentProfile         @relation(fields: [agentId], references: [id])
  provider    String
  status      SubscriptionStatus   @default(TRIAL)
  startedAt   DateTime             @default(now())
  renewalDate DateTime?
  invoices    SubscriptionInvoice[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model SubscriptionInvoice {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  providerRef    String       @unique
  amount         Decimal
  currency       String       @default("SLE")
  paidAt         DateTime?
  status         String
  createdAt      DateTime     @default(now())
}

model WebhookEvent {
  id         String   @id @default(uuid())
  provider   String
  reference  String
  payload    Json
  receivedAt DateTime @default(now())

  @@unique([provider, reference], name: "provider_reference")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation("ActorAudits", fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())
}
